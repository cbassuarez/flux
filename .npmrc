link-workspace-packages=true
prefer-workspace-packages=true
# Use a flat node_modules (like npm) so the build resolves dependencies the way
# it does locally. The monorepo has packages that import @types/node and sibling
# workspace packages without declaring every one; pnpm's default isolated layout
# surfaces those as "Cannot find module" failures in CI. A hoisted layout matches
# the working local build without per-package dependency/lockfile churn.
node-linker=hoisted
