# Dependencies
node_modules/
.pnpm-store/

# OS / editor junk
.DS_Store
*~

# Build outputs (regenerated by `pnpm run build`; CI rebuilds before publish,
# and npm packs dist from disk, so these don't need to be tracked)
packages/*/dist/
packages/viewer/editor-dist/

# Build / tool caches
*.tsbuildinfo
.vite/
.turbo/
coverage/

# Compiled config outputs (source is vite.config.ts)
packages/*/vite.config.js
packages/*/vite.config.d.ts

# Test / run artifacts
test-results/
playwright-report/
out/

# Viewer atomic-write temp files
*.flux.*.tmp

# Logs / env
*.log
.env
.env.local
